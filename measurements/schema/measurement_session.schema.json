{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BodyMeasurementSession",
  "type": "object",
  "required": [
    "measurement_session_id",
    "measured_at",
    "source_type",
    "source_quality",
    "context_time_of_day",
    "measurements"
  ],
  "properties": {
    "measurement_session_id": {
      "type": "string"
    },
    "subject_profile_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "measured_at": {
      "type": "string"
    },
    "measured_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_type": {
      "type": "string"
    },
    "source_quality": {
      "type": "string",
      "enum": [
        "measured_direct",
        "self_reported",
        "imported_record"
      ]
    },
    "context_time_of_day": {
      "type": "string",
      "enum": [
        "morning",
        "unknown",
        "other"
      ]
    },
    "fasting_state": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "before_training": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "measurements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "order_in_session",
          "measurement_type_raw",
          "value_numeric"
        ],
        "properties": {
          "order_in_session": {
            "type": "integer",
            "minimum": 1
          },
          "measurement_type_raw": {
            "type": "string"
          },
          "value_numeric": {
            "type": "number"
          },
          "unit": {
            "type": [
              "string",
              "null"
            ]
          },
          "side_or_scope": {
            "type": [
              "string",
              "null"
            ]
          },
          "raw_value": {
            "type": [
              "string",
              "null"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
